{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "javascript": {
    "globals": ["Bun"]
  },
  "overrides": [
    {
      "includes": [
        "packages/harness/src/index.ts",
        "packages/tui/src/index.ts",
        "packages/headless/src/index.ts",
        "packages/cea/src/context/skill-command-prefix.ts",
        "packages/cea/src/commands/index.ts",
        "packages/harness/src/checkpoint-history.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/harness/src/errors.ts"],
      "linter": {
        "rules": {
          "style": {
            "noEnum": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/harness/src/loop.ts",
        "packages/headless/src/runner.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/harness/src/mcp-types.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNamespace": "off"
          }
        }
      }
    }
  ]
}
